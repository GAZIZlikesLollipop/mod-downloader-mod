{
	"schemaVersion": 1,
	"id": "modrinth-direct",
	"version": "${version}",
	"name": "Modrinth Direct",
	"description": "Automates mod discovery and installation using the Modrinth API.",
	"authors": [
		"Gaziz"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/GAZIZlikesLollipop/modrinth-direct"
	},
	"license": "CC0-1.0",
	"icon": "assets/modrinth-direct/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "org.gaziz.modrinthdirect.ModrinthDirect",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "org.gaziz.modrinthdirect.client.ModrinthDirectClient",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"modrinth-direct.mixins.json",
		{
			"config": "modrinth-direct.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}